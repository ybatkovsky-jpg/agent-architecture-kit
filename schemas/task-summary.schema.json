{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/task-summary.schema.json",
  "title": "TaskSummary",
  "type": "object",
  "required": ["id", "title", "status"],
  "properties": {
    "id": { "type": "string" },
    "title": { "type": "string" },
    "status": { "type": "string", "enum": ["open", "active", "blocked", "closed"] },
    "priority": { "type": "string" },
    "next_action": { "type": ["string", "null"] },
    "artifact_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "depends_on": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
