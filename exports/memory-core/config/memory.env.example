# Copy to memory.env and adjust for your local PostgreSQL installation.
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=pkm_memory
PGUSER=pkm_memory
PGPASSWORD=change-me
# Optional superuser/bootstrap account if CREATE EXTENSION requires it.
PGBOOTSTRAP_DB=postgres
PGBOOTSTRAP_USER=postgres
PGBOOTSTRAP_PASSWORD=
