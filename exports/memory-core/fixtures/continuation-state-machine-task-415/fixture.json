      "must_explain_preexecution_invalidity": true
    },
    "blocked_after_ack_or_running": {
      "description": "When ownership was accepted, BLOCKED must close the current bounded attempt and keep the same continuation_id."
    },
    "terminality": {
      "description": "DONE and BLOCKED are terminal for the current attempt. Reopen requires a new attempt outside this fixture pack."
    }
  },
